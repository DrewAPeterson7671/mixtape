<p style="color: green"><%= notice %></p>

<% content_for :title, "Tracks" %>

<h1>Tracks</h1>

<div id="tracks">
  <% @tracks.each do |track| %>
    <%= render partial: 'track', locals: { track: track, user_pref: @user_prefs[track.id] } %>
    <p>
      <%= link_to "Show this track", track %>
    </p>
  <% end %>
</div>

<%= link_to "New track", new_track_path %>
