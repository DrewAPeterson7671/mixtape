<p style="color: green"><%= notice %></p>

<% content_for :title, "Albums" %>

<h1>Albums</h1>

<div id="albums">
  <% @albums.each do |album| %>
    <%= render partial: 'album', locals: { album: album, user_pref: @user_prefs[album.id] } %>
    <p>
      <%= link_to "Show this album", album %>
    </p>
  <% end %>
</div>

<%= link_to "New album", new_album_path %>
